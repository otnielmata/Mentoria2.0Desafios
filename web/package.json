{
  "name": "mentoria-desafios-web",
  "version": "0.1.0",
  "private": true,
  "description": "Aplicacao web inicial para o Desafios Mentoria 2.0 conectada a API REST.",
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "deploy:check": "node scripts/validate-env.mjs --production && npm run quality",
    "env:check": "node scripts/validate-env.mjs",
    "format": "node scripts/format-check.mjs --write",
    "format:check": "node scripts/format-check.mjs",
    "lint": "node scripts/lint.mjs",
    "quality": "npm run env:check && npm run lint && npm run format:check && npm test && npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "next": "^16.2.9",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "vitest": "^4.1.8"
  }
}
